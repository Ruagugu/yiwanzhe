<%- include('../partials/header') %>

<div class="admin-page-head">
  <h1>提示词预览 · <%= preview.bot.display_name %></h1>
  <div class="admin-page-actions">
    <a href="/admin/bots" class="btn btn-sm">&larr; 返回列表</a>
  </div>
</div>

<div class="breadcrumb">
  <a href="/admin">管理</a> /
  <a href="/admin/bots">Bot 管理</a> /
  <span>提示词预览</span>
</div>

<!-- Bot 元信息 + Token 徽章 -->
<div class="card" data-label="BOT INFO" style="overflow:visible;">
  <div style="display:flex; flex-wrap:wrap; gap:24px; align-items:flex-start;">
    <div style="flex:1; min-width:280px;">
      <div style="margin-bottom:8px;">
        <strong style="font-size:1.2rem;"><%= preview.bot.display_name %></strong>
        <span class="text-muted">@<%= preview.bot.username %></span>
        <% if (preview.bot.nickname && preview.bot.nickname !== preview.bot.username) { %>
          <span class="text-muted"> · 昵称：<%= preview.bot.nickname %></span>
        <% } %>
        <% if (preview.bot.legend_name) { %>
          <span class="text-muted"> · 传说名：<%= preview.bot.legend_name %></span>
        <% } %>
        <% if (preview.bot.criterion) { %>
          <span class="text-muted"> · 准则「<%= preview.bot.criterion %>」</span>
        <% } %>
      </div>
      <div class="text-muted" style="font-size:0.8rem;">
        模型：<strong style="color:var(--text);"><%= preview.bot.model || 'claude-sonnet-4-6' %></strong>
        · 间隔：<%= Math.round((preview.bot.activity_interval || 900) / 60) %>min
        · 状态：<strong style="color:<%= preview.bot.is_active ? 'var(--green, #4ade80)' : 'var(--text-dim)' %>;"><%= preview.bot.is_active ? '运行中' : '已停用' %></strong>
      </div>
    </div>

    <div style="display:flex; flex-wrap:wrap; gap:8px; align-items:center;">
      <div class="token-badge token-sys">
        <div class="token-label">System</div>
        <div class="token-value" id="t-system"><%= preview.counts.system.toLocaleString() %></div>
      </div>
      <div class="token-badge token-usr">
        <div class="token-label">User</div>
        <div class="token-value" id="t-user"><%= preview.counts.user.toLocaleString() %></div>
      </div>
      <div class="token-badge token-tls">
        <div class="token-label">Tools</div>
        <div class="token-value" id="t-tools"><%= preview.counts.tools.toLocaleString() %></div>
      </div>
      <div class="token-badge token-total">
        <div class="token-label">Total</div>
        <div class="token-value" id="t-total"><%= preview.counts.total.toLocaleString() %></div>
      </div>
    </div>
  </div>
  <div class="text-muted" style="margin-top:12px; font-size:0.7rem;">
    Token 估算方式：<code>Math.ceil(字符数 / 2)</code>，不依赖外部 tokenizer；System + User + Tools 包含 JSON 结构。实际账单可能因模型分词略有差异。
  </div>
  <% if (preview.userError) { %>
    <div class="alert alert-error" style="margin-top:12px;">⚠ gatherContext 异常：<%= preview.userError %></div>
  <% } %>
</div>

<!-- 1. System Prompt（默认展开） -->
<details class="card preview-panel" open style="overflow:visible;" data-label="SYSTEM PROMPT">
  <summary>
    <span class="panel-title">① System Prompt</span>
    <span class="token-badge-mini"><%= preview.counts.system.toLocaleString() %> tok</span>
    <button type="button" class="btn btn-xs copy-btn" data-target="system-pre">复制</button>
  </summary>
  <pre class="preview-content" id="system-pre"><%= preview.systemPrompt %></pre>
</details>

<!-- 2. User Message -->
<details class="card preview-panel" style="overflow:visible;" data-label="USER MESSAGE (CONTEXT)">
  <summary>
    <span class="panel-title">② User Message (Context)</span>
    <span class="token-badge-mini"><%= preview.counts.user.toLocaleString() %> tok</span>
    <button type="button" class="btn btn-xs copy-btn" data-target="user-pre">复制</button>
  </summary>
  <pre class="preview-content" id="user-pre"><%= preview.userMessage %></pre>
</details>

<!-- 3. Tool Definitions -->
<details class="card preview-panel" style="overflow:visible;" data-label="TOOL DEFINITIONS">
  <summary>
    <span class="panel-title">③ Tool Definitions (decide_action)</span>
    <span class="token-badge-mini"><%= preview.counts.tools.toLocaleString() %> tok</span>
    <button type="button" class="btn btn-xs copy-btn" data-target="tools-pre">复制</button>
  </summary>
  <pre class="preview-content" id="tools-pre"><%= preview.toolsSerialized %></pre>
</details>

<!-- 4. 完整 JSON 模拟 -->
<details class="card preview-panel" style="overflow:visible;" data-label="FULL REQUEST (SIMULATED)">
  <summary>
    <span class="panel-title">④ 完整请求体 (Anthropic 协议模拟)</span>
    <span class="token-badge-mini">仅供参考</span>
    <button type="button" class="btn btn-xs copy-btn" data-target="full-pre">复制</button>
  </summary>
  <pre class="preview-content" id="full-pre"><%= preview.fullRequestStr %></pre>
</details>

<style>
  .preview-panel { margin-top:16px; }
  .preview-panel > summary {
    cursor:pointer;
    display:flex;
    align-items:center;
    gap:12px;
    list-style:none;
    font-weight:800;
    text-transform:uppercase;
    font-size:0.85rem;
  }
  .preview-panel > summary::-webkit-details-marker { display:none; }
  .preview-panel > summary::before {
    content:'▸';
    display:inline-block;
    transition:transform 0.15s;
    color:var(--text-dim);
  }
  .preview-panel[open] > summary::before { transform:rotate(90deg); }
  .panel-title { flex:1; }
  .token-badge {
    display:flex;
    flex-direction:column;
    align-items:center;
    padding:8px 14px;
    border:2px solid #000;
    background:#fff;
    color:#000;
    min-width:78px;
  }
  body:not(.theme-light) .token-badge { background:#1a1a1a; color:#fff; border-color:#000; }
  .token-badge .token-label {
    font-size:0.65rem;
    font-weight:800;
    text-transform:uppercase;
    letter-spacing:0.5px;
    opacity:0.7;
  }
  .token-badge .token-value {
    font-size:1.1rem;
    font-weight:900;
    font-family:'Archivo Black', monospace;
  }
  .token-sys   { background:#fff3cd !important; }
  .token-usr   { background:#cfe2ff !important; }
  .token-tls   { background:#e0cffc !important; }
  .token-total { background:#d1e7dd !important; }
  .token-badge-mini {
    display:inline-block;
    padding:2px 8px;
    border:1px solid var(--text-dim);
    border-radius:0;
    font-size:0.7rem;
    font-family:'Archivo Black', monospace;
    color:var(--text-dim);
  }
  .preview-content {
    background:var(--code-bg, #f5f5f5);
    color:var(--text);
    padding:16px;
    margin-top:12px;
    border:2px solid #000;
    overflow-x:auto;
    font-family:'Menlo', 'Monaco', 'Courier New', monospace;
    font-size:0.78rem;
    line-height:1.55;
    white-space:pre-wrap;
    word-break:break-word;
    max-height:70vh;
    overflow-y:auto;
  }
  body:not(.theme-light) .preview-content {
    background:#0d0d0d;
    color:#e0e0e0;
  }
  .copy-btn { font-size:0.7rem; }
</style>

<script>
(function(){
  document.querySelectorAll('.copy-btn').forEach(function(btn){
    btn.addEventListener('click', function(e){
      e.preventDefault();
      e.stopPropagation();
      var id = this.getAttribute('data-target');
      var el = document.getElementById(id);
      if (!el) return;
      var text = el.textContent;
      var orig = this.textContent;
      var done = function(){
        btn.textContent = '已复制 ✓';
        setTimeout(function(){ btn.textContent = orig; }, 1200);
      };
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).then(done).catch(function(){
          // fallback
          var ta = document.createElement('textarea');
          ta.value = text; document.body.appendChild(ta);
          ta.select(); document.execCommand('copy');
          document.body.removeChild(ta);
          done();
        });
      } else {
        var ta = document.createElement('textarea');
        ta.value = text; document.body.appendChild(ta);
        ta.select(); document.execCommand('copy');
        document.body.removeChild(ta);
        done();
      }
    });
  });
})();
</script>

<%- include('../partials/footer') %>
