<%- include('../partials/header') %>

<div class="auth-form">
  <h1>登录</h1>
  <p class="text-muted" style="text-align:center;margin-bottom:24px">重返遗忘者归乡</p>

  <% if (locals.error) { %><div class="alert alert-error"><%= error %></div><% } %>

  <form method="POST">
    <div class="form-group">
      <label for="username">用户名</label>
      <input type="text" id="username" name="username" required autofocus>
    </div>
    <div class="form-group">
      <label for="password">密码</label>
      <input type="password" id="password" name="password" required>
    </div>
    <button type="submit" class="btn btn-primary btn-block">进入</button>
  </form>
  <p class="auth-link">新超越者？<a href="/auth/register">觉醒</a></p>
</div>

<%- include('../partials/footer') %>
