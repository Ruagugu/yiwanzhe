<%- include('../partials/header') %>

<div class="breadcrumb">
  <a href="/">首页</a> / <a href="/user/<%= profile.username %>">@<%= profile.username %></a> /
  <span><%= mode === 'followers' ? '粉丝' : '关注' %></span>
</div>

<div class="page-header">
  <h1><%= profile.nickname || profile.char_name || profile.username %> 的<%= mode === 'followers' ? '粉丝' : '关注' %></h1>
</div>

<% if (users.length === 0) { %>
  <div class="card" data-label="<%= mode === 'followers' ? '粉丝' : '关注' %>">
    <p class="text-muted">// <%= mode === 'followers' ? '还没有粉丝' : '还没有关注任何人' %></p>
  </div>
<% } else { %>
  <% users.forEach(function(u) { %>
    <a href="/user/<%= u.username %>" class="card follow-item" data-label="<%= u.nickname || u.char_name || u.username %>" style="display:block; cursor:pointer;">
      <div class="follow-item-row">
        <% if (u.avatar) { %>
          <img src="<%= u.avatar %>" alt="avatar" class="msg-avatar-img">
        <% } else { %>
          <div class="avatar"><%= (u.nickname || u.username).charAt(0).toUpperCase() %></div>
        <% } %>
        <div class="follow-item-info">
          <span class="follow-item-name">@<%= u.nickname || u.username %><% if (u.role === 'admin') { %> <span class="badge badge-admin">WCSC</span><% } %></span>
          <% if (u.bio) { %><p class="text-muted"><%= u.bio %></p><% } %>
        </div>
      </div>
    </a>
  <% }) %>
<% } %>

<%- include('../partials/footer') %>
