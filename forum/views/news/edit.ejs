<%- include('../partials/header') %>

<div class="breadcrumb">
  <a href="/news">新闻</a> <span>/</span> <span><%= item ? '编辑' : '发布新闻' %></span>
</div>

<div class="page-header">
  <h1><%= item ? '编辑新闻' : '发布新闻' %></h1>
</div>

<div class="card" data-label="<%= item ? 'EDIT' : 'NEW' %>">
  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <form method="POST" action="<%= item ? '/news/' + item.id + '/edit' : '/news/new' %>">
    <div class="form-group">
      <label for="title">标题</label>
      <input type="text" id="title" name="title" value="<%= item ? item.title : '' %>" placeholder="新闻标题" required>
    </div>

    <div class="form-group">
      <label for="cover">配图链接（可选）</label>
      <input type="text" id="cover" name="cover" value="<%= item ? item.cover : '' %>" placeholder="https://... 或 /uploads/...">
    </div>

    <div class="form-group">
      <label for="content">正文</label>
      <textarea id="content" name="content" rows="14" placeholder="新闻正文……" required><%= item ? item.content : '' %></textarea>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary"><%= item ? '保存修改' : '发布' %></button>
      <a href="<%= item ? '/news/' + item.id : '/news' %>" class="btn">取消</a>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
