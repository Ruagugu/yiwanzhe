# forum/ 子目录 gitignore（与根 .gitignore 互补）
# ----------------------------------------------------

# 依赖 —— **绝不能跨平台拷贝**
node_modules/
npm-debug.log*

# 数据库（含 WAL 模式的中间文件）
*.db
*.db-shm
*.db-wal
*.db-journal
*.db.bak*

# 论坛运行时产生的上传文件
public/uploads/
uploads/

# 论坛内部的设计文档
docs/

# forum 根目录的临时截图
*.png
cj.txt

# 环境变量
.env
.env.local

# 通用
.DS_Store
Thumbs.db
.vscode/
.idea/
*.tmp
*.swp
*.bak
*.log
