# =========================================================
# 遗忘者归乡论坛 - 仓库 .gitignore
# =========================================================
# 本仓库只收录 forum/ 目录的源代码。
# 运行时产物、依赖、临时文件、截图一律不纳入。
# =========================================================

# 依赖
node_modules/

# 数据库
*.db
*.db-shm
*.db-wal
*.db-journal
*.db.bak*

# 上传文件
uploads/
public/uploads/

# 截图（forum/ 根目录的临时截图）
forum/*.png
forum/cj.txt

# 论坛内部的设计文档（不属于论坛运行本体）
forum/docs/

# 日志
*.log
npm-debug.log*

# 环境变量
.env
.env.local

# 操作系统 / 编辑器
.DS_Store
Thumbs.db
.vscode/
.idea/
*.tmp
*.swp
*.bak
